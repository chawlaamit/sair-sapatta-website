---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const settings = await getEntry('settings', 'site');
const s = settings!.data;
---

<BaseLayout
  title="Contact Us"
  description="Visit the site, give us a call, or drop a message — get in touch with Sair Sapatta."
  path="/contact/"
>
  <section class="section-dark">
    <div class="container-narrow" style="text-align:center;">
      <span class="eyebrow">Get in Touch</span>
      <h1>Contact us</h1>
      <p class="lede" style="margin:22px auto 0;">Visit the site, give us a call, or drop a message — we'd love to show you around Sair Sapatta.</p>
    </div>
    <div class="container" style="padding-top:46px;padding-bottom:clamp(56px,8vw,90px);display:flex;flex-wrap:wrap;gap:24px;">
      <div class="contact-card">
        <div style="width:38px;height:2px;background:var(--gold);margin-bottom:18px;"></div>
        <h3 style="color:var(--gold-l);">Address</h3>
        <p style="font-size:15px;line-height:1.8;color:var(--cream);margin:14px 0 0;">{s.address}</p>
      </div>
      <div class="contact-card">
        <div style="width:38px;height:2px;background:var(--gold);margin-bottom:18px;"></div>
        <h3 style="color:var(--gold-l);">Call &amp; Email</h3>
        <p style="font-size:15px;line-height:1.9;color:var(--cream);margin:14px 0 0;">
          <a href={`tel:${s.phone1.replace(/\s/g, '')}`}>{s.phone1}</a><br />
          <a href={`tel:${s.phone2.replace(/\s/g, '')}`}>{s.phone2}</a><br />
          <a href={`mailto:${s.email}`} style="color:var(--gold-l);">{s.email}</a>
        </p>
      </div>
      <div class="contact-card">
        <div style="width:38px;height:2px;background:var(--gold);margin-bottom:18px;"></div>
        <h3 style="color:var(--gold-l);">Site Visit</h3>
        <p style="font-size:15px;line-height:1.8;color:var(--cream);margin:14px 0 18px;">Open daily · 10:00 AM – 7:00 PM</p>
        <a href="/enquire/" class="btn btn-gold" style="padding:12px 24px;font-size:12px;">Book a visit</a>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div style="border:1px solid #e7e0d2;background:#fff;">
        <iframe
          src="https://www.google.com/maps?q=Sair%20Sapatta%20by%20SCG%20Developers%2C%20Rajpura%E2%80%93Patiala%20Highway%2C%20Rajpura%2C%20Punjab&output=embed"
          width="100%"
          height="420"
          style="border:0;display:block;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
          title="Sair Sapatta location map — Rajpura–Patiala Highway"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
