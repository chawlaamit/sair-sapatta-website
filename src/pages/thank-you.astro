---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You"
  description="Your enquiry has been received."
  path="/thank-you/"
>
  <section class="section-dark" style="min-height:calc(100vh - 74px);display:flex;align-items:center;">
    <div class="container-narrow" style="text-align:center;padding:60px 0;">
      <div style="width:64px;height:64px;border:1px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 22px;color:var(--gold);font-size:28px;font-family:'Cormorant Garamond',serif;">✓</div>
      <h1 style="font-size:clamp(34px,5vw,48px);">Thank you</h1>
      <p class="lede" style="margin:14px auto 26px;">Your enquiry has been received. Our team will contact you shortly.</p>
      <a href="/" class="btn btn-outline">Back to Home</a>
    </div>
  </section>
</BaseLayout>
