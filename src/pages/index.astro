---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandCard from '../components/BrandCard.astro';
import { getEntry, getCollection } from 'astro:content';

const settings = await getEntry('settings', 'site');
const s = settings!.data;
const brands = await getCollection('brands');
const featured = brands.slice(0, 4);
---

<BaseLayout
  title="Premium Commercial Showrooms in Rajpura"
  description={s.heroDescription}
  path="/"
>
  <section class="section-dark">
    <div class="container" style="padding-top:clamp(48px,7vw,96px);padding-bottom:clamp(40px,6vw,60px);display:flex;flex-wrap:wrap;gap:56px;align-items:center;">
      <div style="flex:1 1 460px;min-width:300px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:26px;">
          <span style="width:7px;height:7px;border-radius:50%;background:var(--gold);"></span>
          <span class="eyebrow">{s.heroEyebrow}</span>
        </div>
        <h1>Sair<br />Sapatta</h1>
        <p style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(22px,3vw,30px);color:var(--cream);margin:20px 0 0;font-weight:400;">{s.tagline}</p>
        <p class="hero-text" style="margin-top:22px;">{s.heroDescription}</p>
        <div style="display:flex;flex-wrap:wrap;gap:14px;margin-top:36px;">
          <a href="/brands/" class="btn btn-gold">Explore the Brands</a>
          <a href="/enquire/" class="btn btn-outline">Enquire Now</a>
        </div>
        <div style="display:inline-flex;align-items:center;gap:10px;margin-top:30px;padding:9px 16px;border:1px solid var(--line);border-radius:2px;">
          <span style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);">RERA</span>
          <span style="width:1px;height:14px;background:var(--line);"></span>
          <span style="font-size:12px;letter-spacing:1px;color:var(--gold-l);">{s.rera}</span>
        </div>
      </div>
      <div style="flex:1 1 420px;min-width:300px;">
        <div style="position:relative;border:1px solid var(--line);overflow:hidden;">
          <img src="/images/uploads/hero-banner.png" alt={s.siteName} style="width:100%;height:560px;object-fit:cover;object-position:top;display:block;" />
          <div style="position:absolute;left:0;right:0;bottom:0;padding:22px 26px;background:linear-gradient(to top, rgba(7,13,26,.9), rgba(7,13,26,0));">
            <div style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:26px;color:var(--cream);">Shop. Dine. Unwind.</div>
            <div style="font-size:12px;letter-spacing:1.5px;color:var(--muted);margin-top:6px;">A destination designed for every hour of the day.</div>
          </div>
        </div>
      </div>
    </div>
    <div style="border-top:1px solid var(--line);">
      <div class="container" style="display:flex;flex-wrap:wrap;">
        {s.stats.map((st) => (
          <div style="flex:1 1 200px;padding:26px 8px;text-align:center;border-right:1px solid var(--line);">
            <div style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:40px;color:var(--gold-l);line-height:1;">{st.number}</div>
            <div style="font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-top:8px;">{st.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container-narrow" style="text-align:center;">
      <span class="eyebrow">The Destination</span>
      <h2>One-of-its-kind commercial address in the heart of Rajpura</h2>
      <p class="lede" style="margin:24px auto 0;">Sair Sapatta brings organised, brand-led retail to one of Punjab's fastest-growing towns. Forty-two independent showroom plots — each free to rise across multiple floors — sit on a high-visibility highway frontage, surrounded by a dense, ready catchment.</p>
    </div>
  </section>

  <section class="section section-navy">
    <div class="container">
      <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:20px;margin-bottom:46px;">
        <div>
          <span class="eyebrow">Already On Board</span>
          <h2>Signature brands, already signed</h2>
        </div>
        <a href="/brands/" class="btn btn-outline">View all brands</a>
      </div>
      <div class="grid grid-4">
        {featured.map((b) => (
          <BrandCard name={b.data.name} category={b.data.category} status={b.data.status} statusLabel={b.data.statusLabel} logo={b.data.logo} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div style="text-align:center;margin-bottom:50px;">
        <span class="eyebrow">Why Sair Sapatta</span>
        <h2>An investment built to perform</h2>
      </div>
      <div class="grid grid-4">
        {s.whyCards.map((w) => (
          <div class="card">
            <div style="font-family:'Cormorant Garamond',serif;font-weight:500;font-size:34px;color:var(--gold-d);line-height:1;">{w.number}</div>
            <div style="width:34px;height:2px;background:var(--gold);margin:16px 0 18px;"></div>
            <h3>{w.title}</h3>
            <p style="font-size:14.5px;line-height:1.75;color:var(--muted-ink);margin:12px 0 0;">{w.description}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:46px;">
        <a href="/why-buy/" class="btn btn-gold">Why buy here →</a>
      </div>
    </div>
  </section>

  <section class="section section-navy">
    <div class="container" style="display:flex;flex-wrap:wrap;gap:50px;align-items:center;">
      <div style="flex:1 1 320px;min-width:280px;">
        <span class="eyebrow">The Master Plan</span>
        <h2>42 independent showroom plots</h2>
        <p class="hero-text" style="margin-top:20px;">Each plot is independently owned and can be developed across multiple floors — giving every brand and investor the freedom to build exactly what their business needs.</p>
        <div style="margin-top:36px;">
          <span class="eyebrow">On-Site Amenities</span>
          <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:18px;">
            {[
              'Multiple Entry & Exit Points',
              'Wide Internal Roads (up to 30\')',
              'Dedicated Two-Wheeler Parking',
              "8'-3\" Wide Shopping Corridors",
              'Green Landscaped Area',
              'Electric Sub-Station',
              'Underground Water Tank',
              'Sewage Treatment Plant (STP)',
              'Common Conveniences',
            ].map((a) => (
              <span style="display:inline-flex;align-items:center;gap:8px;padding:9px 16px;border:1px solid var(--line);border-radius:2px;font-size:12px;letter-spacing:1px;color:var(--cream);">
                <span style="width:5px;height:5px;border-radius:50%;background:var(--gold);"></span>{a}
              </span>
            ))}
          </div>
        </div>
        <a href="/enquire/" class="btn btn-outline" style="margin-top:32px;">Request the plan &amp; price list</a>
      </div>
      <div style="flex:1 1 380px;min-width:300px;">
        <a href="/images/uploads/master-plan.jpg" target="_blank" style="display:block;border:1px solid var(--line);background:#fff;">
          <img src="/images/uploads/master-plan.jpg" alt="Sair Sapatta master plan — site layout" style="width:100%;height:auto;display:block;" />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
