---
import { getEntry } from 'astro:content';

const settings = await getEntry('settings', 'site');
const s = settings!.data;
const path = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
  { label: 'Brands', href: '/brands/' },
  { label: 'Why Buy', href: '/why-buy/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Blog', href: '/blog/' }
];

function isActive(href: string) {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand-mark">
      {s.logo ? (
        <img src={s.logo} alt={s.siteName} style="height: 56px; width: auto; display: block;" />
      ) : (
        <span>
          <span class="brand-mark-name">{s.siteName}</span>
          <span class="brand-mark-sub">by SCG Developers</span>
        </span>
      )}
    </a>
    <nav class="main-nav">
      {navItems.map((item) => (
        <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a>
      ))}
      <a href="/enquire/" class="btn btn-gold" style="margin-left: 6px; padding: 12px 24px; font-size: 12px;">Enquire</a>
    </nav>
  </div>
</header>
